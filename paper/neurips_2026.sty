% NeurIPS 2026 LaTeX style file
% Based on official NeurIPS formatting requirements:
% US Letter, 1.5in left margin, 5.5×9in text, 10pt/11pt Times, two-column

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2026}[2026/01/01 NeurIPS 2026 Proceedings]

% Declare options
\newif\if@neurips@final\@neurips@finalfalse
\newif\if@neurips@preprint\@neurips@preprintfalse
\newif\if@neurips@nonanonymous\@neurips@nonanonymousfalse
\newif\if@neurips@lineno\@neurips@linenotrue

\DeclareOption{final}{\@neurips@finaltrue\@neurips@linenofalse}
\DeclareOption{preprint}{\@neurips@preprinttrue\@neurips@nonanonymoustrue}
\DeclareOption{nonanonymous}{\@neurips@nonanonymoustrue}
\DeclareOption{main}{}
\DeclareOption{eandd}{}
\DeclareOption{position}{}
\DeclareOption{creativeai}{}
\DeclareOption{nonatbib}{}
\ProcessOptions\relax

% Page layout
\RequirePackage[letterpaper]{geometry}
\geometry{
  top=1.0in,
  bottom=1.0in,
  left=1.5in,
  right=1.0in,
  headheight=0pt,
  headsep=0pt,
  footskip=0.5in,
}

% Text area: 5.5in wide, 9in tall
% Two-column layout
\RequirePackage{multicol}
\setlength{\columnsep}{0.25in}

% Fonts: Times New Roman, 10pt/11pt
\RequirePackage{times}
\RequirePackage{mathptmx}
\renewcommand{\normalsize}{\fontsize{10}{11}\selectfont}
\renewcommand{\small}{\fontsize{9}{10}\selectfont}
\renewcommand{\footnotesize}{\fontsize{8}{9}\selectfont}

% Paragraph spacing
\setlength{\parindent}{0.2in}
\setlength{\parskip}{0pt plus 1pt}

% Line numbers for review
\if@neurips@lineno
  \RequirePackage[switch,pagewise,mathlines]{lineno}
  \linenumbers
\fi

% Title formatting (14pt bold)
\def\@maketitle{%
  \newpage
  \begin{center}%
    \let\footnote\thanks
    {\fontsize{14}{16}\bfseries\@title\par}%
    \vskip 0.5em%
    {\large\lineskip .5em%
      \begin{tabular}[t]{c}%
        \@author
      \end{tabular}\par}%
    \vskip 1em%
    {\normalsize\@date}%
  \end{center}%
  \par\vskip 0.5em%
}

% Abstract formatting
\renewenvironment{abstract}{%
  \small
  \begin{center}%
    {\bfseries\abstractname\vspace{-.5em}\vspace{\z@}}%
  \end{center}%
  \quotation
}{%
  \endquotation
  \vskip 0.5em%
}

% Section formatting (12pt bold)
\RequirePackage{titlesec}
\titleformat{\section}{\fontsize{12}{13}\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\fontsize{11}{12}\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\fontsize{10}{11}\bfseries}{\thesubsubsection}{1em}{}

% Reference font (8pt)
\RequirePackage[numbers,sort&compress]{natbib}
\setlength{\bibsep}{0pt plus 0.3ex}

% Captions
\RequirePackage{caption}
\captionsetup{font=small,labelfont=bf,skip=4pt}

% Hyperlinks
\RequirePackage[colorlinks,citecolor=blue,linkcolor=blue,urlcolor=blue]{hyperref}

% Math
\RequirePackage{amsmath,amssymb,amsfonts}
\RequirePackage{bm}

% Tables
\RequirePackage{booktabs}
\RequirePackage{multirow}

% Figures
\RequirePackage{graphicx}
\graphicspath{{figures/}}

% Checklist
\RequirePackage{enumitem}
\newlist{checklist}{itemize}{1}
\setlist[checklist]{label=$\square$}

% Anonymous submission
\if@neurips@final\else
  \if@neurips@nonanonymous\else
    \author{Anonymous Author(s)}
    \renewcommand{\thanks}[1]{}
  \fi
\fi

% Preprint footer
\if@neurips@preprint
  \RequirePackage{fancyhdr}
  \pagestyle{fancy}
  \fancyhf{}
  \fancyfoot[L]{Preprint. Work in progress.}
  \renewcommand{\headrulewidth}{0pt}
\fi

% Suppress page numbers for non-preprint
\if@neurips@preprint\else
  \pagenumbering{gobble}
\fi

\endinput
